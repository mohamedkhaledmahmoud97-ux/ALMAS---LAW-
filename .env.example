# ALMAS LAW Docker Compose - Example Environment Configuration
# Copy this file to .env and update with your values
# For production, use strong, unique passwords generated with tools like:
#   openssl rand -base64 32

# PostgreSQL Configuration
# Database name for the application
POSTGRES_DB=almas_db

# PostgreSQL superuser credentials
POSTGRES_USER=almas_admin
POSTGRES_PASSWORD=ChangeMe_SecurePassword123!

# Port to expose PostgreSQL on host
POSTGRES_PORT=5432

# Database for Keycloak (will be created automatically)
KEYCLOAK_DB=keycloak

# Qdrant Vector Database Configuration
# API key for Qdrant access control
QDRANT_API_KEY=qdrant_key_change_me

# REST API port
QDRANT_PORT=6333

# gRPC service port
QDRANT_GRPC_PORT=6334

# Neo4j Graph Database Configuration
# Default username (typically cannot be changed)
NEO4J_USER=neo4j

# Neo4j password - must be at least 8 characters
NEO4J_PASSWORD=ChangeMe_Neo4jPassword123!

# Neo4j HTTP/browser port
NEO4J_HTTP_PORT=7474

# Neo4j Bolt protocol port (for clients)
NEO4J_BOLT_PORT=7687

# Redis Cache Configuration
# Password for Redis authentication
REDIS_PASSWORD=ChangeMe_RedisPassword123!

# Redis port
REDIS_PORT=6379

# MinIO Object Storage Configuration
# Root username for MinIO console
MINIO_ROOT_USER=minioadmin

# Root password for MinIO console
MINIO_ROOT_PASSWORD=ChangeMe_MinIOPassword123!

# MinIO S3 API port
MINIO_API_PORT=9000

# MinIO web console port
MINIO_CONSOLE_PORT=9001

# Keycloak Identity & Access Management
# Keycloak admin username
KEYCLOAK_ADMIN=admin

# Keycloak admin password
KEYCLOAK_ADMIN_PASSWORD=ChangeMe_KeycloakPassword123!

# Keycloak web console port
KEYCLOAK_PORT=8080

# Application Environment
# Values: development, staging, production
ENVIRONMENT=development

# Logging level
# Values: debug, info, warn, error
LOG_LEVEL=info
